<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#3290c8"
        android:padding="3dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/image_round"
            android:backgroundTint="@color/white"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Author Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_profile_image"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/profilebtn_filled"
                    />

                <TextView
                    android:id="@+id/tv_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="Username"
                    android:textColor="#3290c8"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>


            <!-- PHOTO -->
            <ImageView
                android:id="@+id/iv_image"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/image_round_2"
                android:backgroundTint="#58AFFF"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/memorybtn_filled" />


            <!-- META ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_likes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="❤ 0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!--            <ImageButton-->
                <!--                android:id="@+id/btn_like"-->
                <!--                style="?android:attr/borderlessButtonStyle"-->
                <!--                android:layout_width="0dp"-->
                <!--                android:layout_height="20dp"-->
                <!--                android:scaleType="center"-->
                <!--                android:layout_weight="1"-->
                <!--                android:src="@drawable/memorybtn_empty"-->
                <!--                app:tint="@color/black"/>-->

                <!--            <ImageButton-->
                <!--                android:id="@+id/btn_comment"-->
                <!--                style="?android:attr/borderlessButtonStyle"-->
                <!--                android:layout_width="0dp"-->
                <!--                android:layout_height="20dp"-->
                <!--                android:layout_weight="1"-->
                <!--                android:layout_marginStart="24dp"-->
                <!--                android:src="@drawable/chatbtn_empty"-->
                <!--                app:tint="@color/black"/>-->

                <TextView
                    android:id="@+id/mem_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:text="01-12-26"

                    android:textColor="#808080"
                    android:textSize="13sp" />
            </LinearLayout>


            <!-- TITLE -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:text="Post title !!"
                android:textColor="#3290c8"
                android:textSize="16sp"
                android:textStyle="bold" />


            <!-- CAPTION -->
            <TextView
                android:id="@+id/tv_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:ellipsize="end"
                android:maxLines="3"
                android:text="Reflecting on today ☕"
                android:textColor="#3290c8"
                android:textSize="14sp" />


            <!-- ACTION BUTTONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_like"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:scaleType="center"
                    android:src="@drawable/memorybtn_empty"
                    app:tint="#3290c8" />

                <ImageButton
                    android:id="@+id/btn_comment"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:src="@drawable/chatbtn_empty"
                    app:tint="#3290c8" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>